{
  "name": "wiki-security-social",
  "version": "0.1.0-rc.3",
  "description": "Social Authentication Security plugin for Federated Wiki.",
  "license": "MIT",
  "author": "Paul Rodwell <paul.rodwell@btinternet.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fedwiki/wiki-security-social.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "npm run test && npm run build:client && npm run build:dialog && npm run build:server",
    "build:client": "(npm run clean:client || true) && node scripts/build-client.js",
    "build:dialog": "(npm run clean:dialog || true) && node scripts/build-dialog.js",
    "build:server": "(npm run clean:server || true) && node scripts/build-server.js",
    "clean": "(npm run clean:client || true) && (npm run clean:dialog || true) && npm run clean:server",
    "clean:client": "rm client/security.js client/security.js.map",
    "clean:dialog": "rm client/auth-dialog.js client/auth-dialog.js.map",
    "clean:server": "rm server/social.js server/social.js.map",
    "test": "node --test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "grunt-git-authors": "^3.2.0",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "better-auth": "^1.6.19",
    "express-handlebars": "^9.0.1"
  }
}
